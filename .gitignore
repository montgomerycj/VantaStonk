node_modules/
dist/
.env
.mcp.json

# Business data — auto-generated runtime state (scan outputs, AI context,
# score snapshots, etc.) stays local. Curated config (watchlist, themes)
# is explicitly allowed through.
data/*.json
!data/.gitkeep
!data/watchlist.json

# SQLite DBs are per-machine scan history — syncing them via git causes
# binary merge conflicts. Each machine keeps its own local DB.
data/*.db
data/*.db-*

# Python
__pycache__/
*.pyc
.pytest_cache/

# OS files
.DS_Store
Thumbs.db
